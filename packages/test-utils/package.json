{
  "name": "test-utils",
  "description": "Test utils for typeweaver packages",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src/*": {
      "types": "./src/*",
      "default": "./src/*"
    }
  },
  "scripts": {
    "build": "echo 'No build needed for test-utils'",
    "typecheck": "echo 'Skipping typecheck for test-utils (requires 8GB+ memory)'",
    "format": "oxfmt",
    "test-project:gen": "pnpm exec typeweaver generate --output src/test-project/output --input src/test-project/spec/index.ts --plugins clients,aws-cdk,hono,server",
    "test:gen": "pnpm run test-project:gen"
  },
  "keywords": [
    "typeweaver",
    "test",
    "utils"
  ],
  "devDependencies": {
    "@hono/node-server": "^1.19.11",
    "@rexeus/typeweaver": "workspace:^",
    "@rexeus/typeweaver-aws-cdk": "workspace:^",
    "@rexeus/typeweaver-clients": "workspace:^",
    "@rexeus/typeweaver-core": "workspace:^",
    "@rexeus/typeweaver-gen": "workspace:^",
    "@rexeus/typeweaver-hono": "workspace:^",
    "@rexeus/typeweaver-server": "workspace:^",
    "@rexeus/typeweaver-types": "workspace:^",
    "deepmerge": "^4.3.1",
    "get-port": "^7.2.0",
    "hono": "^4.12.9",
    "zod": "^4.3.6"
  }
}
